msgid "More information about Email Approvals for Gravity Forms"
msgstr "Plus d'informations sur Email Approvals for Gravity Forms"

msgid "View details"
msgstr "Voir les détails"

msgid "Report a Bug"
msgstr "Signaler un bug"

msgid "Report a Bug (install Bug Reporter)"
msgstr "Signaler un bug (installer Bug Reporter)"

msgid "Email Approvals for Gravity Forms requires Gravity Forms to be installed and active."
msgstr "Email Approvals for Gravity Forms nécessite que Gravity Forms soit installé et actif."

msgid "Plugin dependency missing"
msgstr "Dépendance du plugin manquante"

msgid "Approval Request"
msgstr "Demande d'approbation"

msgid "Approval Approved"
msgstr "Approbation validée"

msgid "Approval Rejected"
msgstr "Approbation rejetée"

msgid "Approval Pages"
msgstr "Pages d'approbation"

msgid "Customize the public confirmation and result pages used by Approval Request links. Gravity Forms merge tags are supported."
msgstr "Personnalisez les pages publiques de confirmation et de résultat utilisées par les liens de demande d'approbation. Les merge tags Gravity Forms sont pris en charge."

msgid "Confirmation title"
msgstr "Titre de confirmation"

msgid "Approve confirmation text"
msgstr "Texte de confirmation d'approbation"

msgid "Reject confirmation text"
msgstr "Texte de confirmation de rejet"

msgid "Confirm button label"
msgstr "Libellé du bouton de confirmation"

msgid "Approved result text"
msgstr "Texte de résultat après approbation"

msgid "Rejected result text"
msgstr "Texte de résultat après rejet"

msgid "Approval Status"
msgstr "Statut d'approbation"

msgid "Approval Approve URL"
msgstr "URL d'approbation"

msgid "Approval Reject URL"
msgstr "URL de rejet"

msgid "Approval Approve Button"
msgstr "Bouton d'approbation"

msgid "Approval Reject Button"
msgstr "Bouton de rejet"

msgid "Approve"
msgstr "Approuver"

msgid "Reject"
msgstr "Rejeter"

msgid "Reset Status"
msgstr "Réinitialiser le statut"

msgid "Pending"
msgstr "En attente"

msgid "Approved"
msgstr "Approuvé"

msgid "Rejected"
msgstr "Rejeté"

msgid "Approval"
msgstr "Approbation"

msgid "You are not allowed to process these entries."
msgstr "Vous n'êtes pas autorisé à traiter ces entrées."

msgid "The approval action is currently unavailable."
msgstr "L'action d'approbation est actuellement indisponible."

msgid "Select at least one entry to update its approval status."
msgstr "Sélectionnez au moins une entrée pour mettre à jour son statut d'approbation."

msgid "Admin"
msgstr "Admin"

msgid "Current status:"
msgstr "Statut actuel :"

msgid "Change status"
msgstr "Changer le statut"

msgid "Apply"
msgstr "Appliquer"

msgid "Reset"
msgstr "Réinitialiser"

msgid "This approval link is invalid or expired."
msgstr "Ce lien d'approbation est invalide ou expiré."

msgid "This approval request has already been processed."
msgstr "Cette demande d'approbation a déjà été traitée."

msgid "Choose an action:"
msgstr "Choisissez une action :"

msgid "Not requested"
msgstr "Non demandé"

msgid "The approval action could not be verified."
msgstr "L'action d'approbation n'a pas pu être vérifiée."

msgid "You are not allowed to process this entry."
msgstr "Vous n'êtes pas autorisé à traiter cette entrée."

msgid "This entry is already pending approval."
msgstr "Cette entrée est déjà en attente d'approbation."

msgid "The entry has been reset to pending."
msgstr "L'entrée a été réinitialisée en attente."

msgid "%d entry approved."
msgid_plural "%d entries approved."
msgstr[0] "%d entrée approuvée."
msgstr[1] "%d entrées approuvées."

msgid "%d entry rejected."
msgid_plural "%d entries rejected."
msgstr[0] "%d entrée rejetée."
msgstr[1] "%d entrées rejetées."

msgid "%d entry reset to pending."
msgid_plural "%d entries reset to pending."
msgstr[0] "%d entrée réinitialisée en attente."
msgstr[1] "%d entrées réinitialisées en attente."

msgid "%d entry skipped because its current status was not compatible."
msgid_plural "%d entries skipped because their current status was not compatible."
msgstr[0] "%d entrée ignorée car son statut actuel n'était pas compatible."
msgstr[1] "%d entrées ignorées car leurs statuts actuels n'étaient pas compatibles."

msgid "%d entry could not be loaded."
msgid_plural "%d entries could not be loaded."
msgstr[0] "%d entrée n'a pas pu être chargée."
msgstr[1] "%d entrées n'ont pas pu être chargées."

msgid "No entries were updated."
msgstr "Aucune entrée n'a été mise à jour."

msgid "The entry has been approved."
msgstr "L'entrée a été approuvée."

msgid "The entry has been rejected."
msgstr "L'entrée a été rejetée."

msgid "Confirm approval action"
msgstr "Confirmer l'action d'approbation"

msgid "You are about to approve this entry."
msgstr "Vous êtes sur le point d'approuver cette entrée."

msgid "You are about to reject this entry."
msgstr "Vous êtes sur le point de rejeter cette entrée."

msgid "Confirm"
msgstr "Confirmer"

msgid "<p>See <a href=\"https://github.com/%1$s/%2$s/releases\" target=\"_blank\" rel=\"noopener noreferrer\">GitHub releases</a> for changelog.</p>"
msgstr "<p>Voir les <a href=\"https://github.com/%1$s/%2$s/releases\" target=\"_blank\" rel=\"noopener noreferrer\">releases GitHub</a> pour le journal des modifications.</p>"

msgid "Requires Gravity Forms:"
msgstr "Gravity Forms requis :"

msgid "%s or higher"
msgstr "%s ou supérieur"

msgid "Unable to rename the update folder. Please retry or update manually."
msgstr "Impossible de renommer le dossier de mise à jour. Veuillez réessayer ou effectuer une mise à jour manuelle."

msgid "Leave unchanged"
msgstr "Laisser inchangé"

msgid "Update Field After Confirmation"
msgstr "Mettre à jour un champ après confirmation"

msgid "Optionally update one supported entry field after the approver confirms their decision. You can either apply a predefined value automatically or let the approver choose the value on the confirmation page."
msgstr "Mettez éventuellement à jour un champ d'entrée pris en charge après que l'approbateur a confirmé sa décision. Vous pouvez soit appliquer automatiquement une valeur prédéfinie, soit laisser l'approbateur choisir la valeur sur la page de confirmation."

msgid "Update behavior"
msgstr "Comportement de mise à jour"

msgid "Choose whether the value is applied automatically when the link is confirmed or selected by the approver on the confirmation page."
msgstr "Choisissez si la valeur est appliquée automatiquement lorsque le lien est confirmé ou si elle est sélectionnée par l'approbateur sur la page de confirmation."

msgid "Field to update"
msgstr "Champ à mettre à jour"

msgid "Choose one supported field to update after approval or rejection."
msgstr "Choisissez un champ pris en charge à mettre à jour après l'approbation ou le rejet."

msgid "Approved value"
msgstr "Valeur en cas d'approbation"

msgid "Used for text-like target fields. Merge tags are supported. Leave blank to keep the field unchanged."
msgstr "Utilisé pour les champs cibles de type texte. Les merge tags sont pris en charge. Laissez vide pour conserver la valeur actuelle du champ."

msgid "Rejected value"
msgstr "Valeur en cas de rejet"

msgid "Approved choice"
msgstr "Choix en cas d'approbation"

msgid "Used for drop down and multiple choice target fields. Leave unchanged to keep the current value."
msgstr "Utilisé pour les champs cibles liste déroulante et choix multiple. Laissez inchangé pour conserver la valeur actuelle."

msgid "Rejected choice"
msgstr "Choix en cas de rejet"

msgid "Approved choices"
msgstr "Choix en cas d'approbation"

msgid "Used for checkbox and multi select target fields. Leave empty to keep the current value."
msgstr "Utilisé pour les champs cibles cases à cocher et sélection multiple. Laissez vide pour conserver la valeur actuelle."

msgid "Rejected choices"
msgstr "Choix en cas de rejet"

msgid "Approval status changed to %s."
msgstr "Le statut d'approbation a été changé en %s."

msgid "Source: %s"
msgstr "Source : %s"

msgid "Actor: %s"
msgstr "Acteur : %s"

msgid "Recipient: %s"
msgstr "Destinataire : %s"

msgid "IP: %s"
msgstr "IP : %s"

msgid "Notification: %1$s (ID: %2$s)"
msgstr "Notification : %1$s (ID : %2$s)"

msgid "Notification: %s"
msgstr "Notification : %s"

msgid "Message field updated: %1$s (%2$s)"
msgstr "Champ de message mis à jour : %1$s (%2$s)"

msgid "Field updated: %1$s (%2$s)"
msgstr "Champ mis à jour : %1$s (%2$s)"

msgid "Old value: %s"
msgstr "Ancienne valeur : %s"

msgid "New value: %s"
msgstr "Nouvelle valeur : %s"

msgid "Choose a value"
msgstr "Choisir une valeur"

msgid "Do not update any field"
msgstr "Ne mettre à jour aucun champ"

msgid "Set a predefined value automatically"
msgstr "Appliquer automatiquement une valeur prédéfinie"

msgid "Let the approver choose the value"
msgstr "Laisser l'approbateur choisir la valeur"

msgid "Field %d"
msgstr "Champ %d"

msgid "%1$s (%2$s)"
msgstr "%1$s (%2$s)"

msgid "The approval request could not be processed."
msgstr "La demande d'approbation n'a pas pu être traitée."

msgid "(empty)"
msgstr "(vide)"
